    // r * 0x100000000 + n - (0xffffffff * 0x100000000) - 0xffffffff
    // (r - 0xffffffff) * 0x100000000 + n - 0xffffffff
    return (decodeUint32(state) - 0xffffffff) * 0x100000000 + decodeUint32(state) - 0xffffffff
