  async downgrade() {
    if (!this.upgraded) return true

    const rx = this.storage.read()
    const nodePromises = []

    for (const r of this.roots) {
      nodePromises.push(rx.getTreeNode(r.index))
    }

    rx.tryFlush()

    const nodes = await Promise.all(nodePromises)

    for (let i = 0; i < this.roots.length; i++) {
