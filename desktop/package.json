{
  "name": "pearguard-desktop",
  "version": "1.0.16",
  "description": "PearGuard desktop child client",
  "homepage": "https://github.com/peerloomllc/pearguard",
  "author": {
    "name": "PeerLoom LLC",
    "email": "support@peerloomllc.com"
  },
  "private": true,
  "main": "src/main/index.js",
  "scripts": {
    "prepack": "node scripts/prepack.js",
    "prestart": "node scripts/prepack.js",
    "presmoke": "node scripts/prepack.js",
    "presmoke:ui": "node scripts/prepack.js",
    "prestart:dev-linux": "node scripts/prepack.js",
    "check:vendor": "node scripts/check-vendor.js",
    "postinstall": "node scripts/prepack.js",
    "start": "electron .",
    "start:dev-linux": "ELECTRON_DISABLE_SANDBOX=1 electron --disable-gpu --disable-software-rasterizer .",
    "smoke": "ELECTRON_DISABLE_SANDBOX=1 PEARGUARD_SMOKE=1 electron --disable-gpu --disable-software-rasterizer .",
    "smoke:ui": "ELECTRON_DISABLE_SANDBOX=1 PEARGUARD_UI_SMOKE=1 electron --disable-gpu --disable-software-rasterizer .",
    "test:enforcement": "node tests/enforcement.smoke.js",
    "test:usage-sleep": "node tests/usage-sleep.smoke.js",
    "test": "node tests/enforcement.smoke.js && node tests/usage-sleep.smoke.js",
    "rebuild": "electron-rebuild",
    "build": "node scripts/prepack.js && electron-builder --win",
    "build:linux": "node scripts/prepack.js && electron-builder --linux",
    "dist": "npm run build"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "b4a": "^1.8.0",
    "electron-updater": "^6.8.3",
    "hyperbee": "^2.27.3",
    "hypercore": "^11.26.0",
    "hypercore-errors": "^1.5.0",
    "hyperdht": "^6.29.0",
    "hyperswarm": "^4.17.0",
    "sodium-native": "^4.3.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.peerloomllc.pearguard",
    "productName": "PearGuard",
    "npmRebuild": false,
    "afterPack": "build/afterPack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "vendor/**/*",
      "build/icon.ico",
      "build/icon.png",
      "package.json",
      "!**/*.test.js",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples,docs,doc,.bin}",
      "!**/prebuilds/**",
      "**/prebuilds/win32-*/**",
      "**/prebuilds/linux-*/**",
      "**/prebuilds/darwin-*/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "pearguard-v${version}.${ext}",
      "extraResources": [
        {
          "from": "build/watchdog.vbs",
          "to": "watchdog.vbs"
        },
        {
          "from": "build/watchdog.ps1",
          "to": "watchdog.ps1"
        },
        {
          "from": "vendor/nssm/nssm.exe",
          "to": "nssm.exe"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "synopsis": "PearGuard child device client",
      "description": "Peer-to-peer parental control child client. Pairs with a parent device over Hyperswarm and reports activity.",
      "artifactName": "pearguard-v${version}.${ext}",
      "executableName": "pearguard",
      "desktop": {
        "Name": "PearGuard",
        "StartupWMClass": "PearGuard"
      },
      "extraResources": [
        {
          "from": "build/gnome-extension",
          "to": "gnome-extension",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "deb": {
      "afterInstall": "build/deb-postinst.sh",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libdrm2",
        "libgbm1",
        "libxcb-dri3-0"
      ],
      "recommends": [
        "librsvg2-bin",
        "libfuse2 | libfuse2t64"
      ],
      "fpm": [
        "--replaces",
        "pearguard-windows",
        "--conflicts",
        "pearguard-windows"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "peerloomllc",
        "repo": "pearguard"
      }
    ]
  }
}
