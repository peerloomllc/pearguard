function toMap(nodes) {
  const m = new Map()
  for (const node of nodes) m.set(node.index, node)
  return m
}

function isCompat(key, manifest) {
  return !!(
    manifest &&
    manifest.signers.length === 1 &&
    b4a.equals(key, manifest.signers[0].publicKey)
