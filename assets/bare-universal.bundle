  if (n < -0xffff) {
    state.buffer[state.start++] = 0x02

    n += 0xffffffff
    encodeUint32(state, n)
    return
  }

  // Negative 16bit
  if (n < -0xff) {
    state.buffer[state.start++] = 0x03

    n += 0xffff
    state.buffer[state.start++] = n >>> 8
    state.buffer[state.start++] = n
    return
  }

  // Negative 8bit
  if (n < 0) {
    state.buffer[state.start++] = 0x04

    n += 0xff
    state.buffer[state.start++] = n
    return
