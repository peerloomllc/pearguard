  "name": "hypercore-storage",
  "version": "2.7.1",
  "main": "index.js",
  "files": [
    "index.js",
    "lib/*.js",
    "spec/hyperschema/*.js",
    "migrations/0/*.js"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "prettier --check . && lunte",
    "test": "npm run test:node && npm run test:bare",
